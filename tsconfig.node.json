{
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/db/**/*"],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "types": ["electron-vite/node", "node"]
  }
}
